```{=html}
<% const listingId = 'listing-' + Math.random().toString(36).substr(2, 9); %>
<div class="research project-list" data-listing-id="<%= listingId %>">
<ul class="list">
    <% for (const item of items) { %>
        <li class="project" <%=metadataAttrs(item) %> data-listing-categories="<%= item.categories ? item.categories.join(',') : '' %>">
            <div class="project-content listing-pub-info">
                <p><%= item['pub-info'].reference %></p>
            </div>

            <% if(item.categories) { %>
            <div class="project-categories">
                <% for (const cat of item.categories) { %>
                    <div class="project-category">
                        <a href="javascript:void(0)" class="category-filter" data-category="<%= cat %>" data-listing="<%= listingId %>"><%= cat %></a>
                    </div>
                    <% } %>
            </div>
            <% } %>

            <% // Loop through the haiku lines and prepend a / to all but the first %>
            <% if (item.haiku) { %>
            <div class="haiku">
            <% for (var i=0; i <= item.haiku.length - 1; i++) { %>
                <% if (i > 0) { %> / <% } %><%= item.haiku[i] %>
            <% } %>
            </div>
            <% } %>
            
            <div class="project-details-listing">
                <ul class="project-links">
                    <li class="project-link details">
                        <a href="<%- item.path %>" class="listing-name">
                            <i class="fa-solid fa-circle-info"></i> Full details »
                        </a>
                    </li>
                    <% if (item['pub-info'].links) { %>
                        <% for (const link of item['pub-info'].links) { %>
                    <li class="project-link">
                        <% if (link.local) { %>
                        <a href="<%- item.path.substring(0, item.path.lastIndexOf('/')) %>/<%- link.url %>">
                        <% } else { %>
                        <a href="<%- link.url %>">
                        <% } %>
                            <i class="<%- link.icon %>"></i> <%= link.name %>
                        </a>
                    </li>
                        <% } %>
                    <% } %>
                </ul>
            </div>
        </li>
        <% } %>
</ul>
</div>

<script>
// Initialize category filtering - runs once when first listing loads.
// A category click filters ALL research listings on the page at once,
// so a user can pick e.g. "Discrimination" and see matching items across
// Publications, Working Papers, and Works in Progress simultaneously.
(function() {
  if (window.categoryFilterInitialized) return;
  window.categoryFilterInitialized = true;

  var activeCategory = null;

  function init() {
    document.querySelectorAll('.category-filter').forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var category = this.getAttribute('data-category');
        activeCategory = (activeCategory === category) ? null : category;
        applyFilter(activeCategory);
      });
    });
  }

  function applyFilter(category) {
    document.querySelectorAll('.research.project-list').forEach(function(container) {
      container.querySelectorAll('.project').forEach(function(item) {
        var categories = item.getAttribute('data-listing-categories') || '';
        var match = !category || categories.split(',').indexOf(category) !== -1;
        item.classList.toggle('d-none', !match);
        item.style.display = match ? '' : 'none';
      });
      updateNoMatchingMessage(container);
    });
    updateCategoryLinks(category);
  }

  function updateNoMatchingMessage(listingContainer) {
    var anyVisible = Array.from(listingContainer.querySelectorAll('.project')).some(function(item) {
      return !item.classList.contains('d-none');
    });
    var noMatchMsg = listingContainer.parentElement.querySelector('.listing-no-matching');
    if (noMatchMsg) {
      noMatchMsg.classList.toggle('d-none', anyVisible);
    }
  }

  function updateCategoryLinks(activeCategory) {
    document.querySelectorAll('.category-filter').forEach(function(link) {
      var category = link.getAttribute('data-category');
      link.classList.toggle('active', category === activeCategory);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
```